---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import { render } from 'astro:content';

export async function getStaticPaths() {
  const publications = await getCollection('publications');
  return publications.map((pub) => ({
    params: { slug: pub.id },
    props: { pub },
  }));
}

const { pub } = Astro.props;
const { Content } = await render(pub);

const statusLabels = {
  'published': { text: 'Published', class: 'badge-success' },
  'submitted': { text: 'Submitted', class: 'badge-warning' },
  'in-preparation': { text: 'In Preparation', class: 'badge-info' },
};

const formatDate = (date: Date) => {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
};
---

<BaseLayout title={pub.data.title} description={pub.data.journal || 'Research publication'}>
  <article class="container mx-auto px-4 py-16 max-w-4xl">
    <!-- Back Button -->
    <div class="mb-8">
      <a href="/publications" class="btn btn-ghost btn-sm">
        ← Back to Publications
      </a>
    </div>

    <!-- Hero Image -->
    {pub.data.image && (
      <figure class="mb-8">
        <Image
          src={pub.data.image}
          alt={pub.data.title}
          width={1200}
          height={600}
          class="rounded-xl w-full object-cover max-h-96"
          format="webp"
        />
      </figure>
    )}

    <!-- Title and Metadata -->
    <header class="mb-8">
      <h1 class="text-4xl font-bold mb-4">{pub.data.title}</h1>

      <div class="flex flex-wrap gap-4 items-center text-sm text-base-content/70 mb-4">
        <span class={`badge ${statusLabels[pub.data.status].class}`}>
          {statusLabels[pub.data.status].text}
        </span>
        {pub.data.journal && (
          <span class="font-medium text-primary">{pub.data.journal}</span>
        )}
        <span>{formatDate(pub.data.date)}</span>
      </div>

      {pub.data.doi && (
        <p class="text-sm text-base-content/60">
          <span class="font-semibold">DOI:</span>{' '}
          <a
            href={`https://doi.org/${pub.data.doi}`}
            target="_blank"
            rel="noopener noreferrer"
            class="link link-primary"
          >
            {pub.data.doi}
          </a>
        </p>
      )}
    </header>

    <!-- Content -->
    <div class="prose prose-lg max-w-none mb-8">
      <Content />
    </div>

    <!-- Actions -->
    <div class="flex gap-4 mt-12">
      {pub.data.url && (
        <a
          href={pub.data.url}
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-primary"
        >
          View Full Article
        </a>
      )}
      {pub.data.doi && (
        <a
          href={`https://doi.org/${pub.data.doi}`}
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-outline"
        >
          View on DOI
        </a>
      )}
    </div>

    <!-- Back Button (Bottom) -->
    <div class="mt-16 pt-8 border-t border-base-300">
      <a href="/publications" class="btn btn-ghost">
        ← Back to Publications
      </a>
    </div>
  </article>
</BaseLayout>
