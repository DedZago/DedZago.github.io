---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { render } from 'astro:content';

export async function getStaticPaths() {
  const experiences = await getCollection('experience');
  return experiences.map((exp) => ({
    params: { slug: exp.id },
    props: { exp },
  }));
}

const { exp } = Astro.props;
const { Content } = await render(exp);

const formatDateRange = (start: string, end?: string) => {
  return end ? `${start} — ${end}` : `${start} — present`;
};
---

<BaseLayout title={`${exp.data.title} at ${exp.data.company}`} description={`Experience at ${exp.data.company}`}>
  <article class="container mx-auto px-4 py-16 max-w-4xl">
    <!-- Back Button -->
    <div class="mb-8">
      <a href="/#experience" class="btn btn-ghost btn-sm">
        ← Back to Experience
      </a>
    </div>

    <!-- Header -->
    <header class="mb-12">
      <div class="badge badge-primary badge-lg mb-4">
        {formatDateRange(exp.data.startDate, exp.data.endDate)}
      </div>

      <h1 class="text-4xl font-bold mb-2">{exp.data.title}</h1>
      <p class="text-2xl text-primary font-medium mb-2">{exp.data.company}</p>
      <p class="text-lg text-base-content/60">{exp.data.location}</p>
    </header>

    <!-- Content -->
    <div class="prose prose-lg max-w-none">
      <Content />
    </div>

    <!-- Back Button (Bottom) -->
    <div class="mt-16 pt-8 border-t border-base-300">
      <a href="/#experience" class="btn btn-ghost">
        ← Back to Experience
      </a>
    </div>
  </article>
</BaseLayout>
