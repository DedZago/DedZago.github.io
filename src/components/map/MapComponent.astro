---
import type { LocationPin } from '@/types/map';

interface Props {
  pins: LocationPin[];
  mapId?: string;
  initialCenter?: [number, number];
  initialZoom?: number;
}

const {
  pins,
  mapId = 'locations-map',
  initialCenter = [12.0, 45.0],
  initialZoom = 4,
} = Astro.props;

const containerId = `${mapId}-container`;
---

<div
  id={containerId}
  class="relative w-full h-full min-h-[500px] rounded-xl overflow-hidden"
  data-pins={JSON.stringify(pins)}
  data-center={JSON.stringify(initialCenter)}
  data-zoom={initialZoom}
>
  <div class="absolute top-4 left-4 right-4 z-10 flex justify-center">
    <div id="map-filters" class="flex flex-wrap gap-1.5 px-2 py-1 bg-base-200/60 rounded-full backdrop-blur-sm"></div>
  </div>
</div>

<script>
  import maplibregl from 'maplibre-gl';
  import 'maplibre-gl/dist/maplibre-gl.css';

  const container = document.querySelector('[id$="-container"][data-pins]') as HTMLElement;
  if (!container) throw new Error('Map container not found');

  const pinsData: any[] = JSON.parse(container.dataset.pins!);
  const initialCenter = JSON.parse(container.dataset.center!) as [number, number];
  const initialZoom = Number(container.dataset.zoom);

  const TYPE_COLORS: Record<string, string> = {
    presentation: '#6366f1',
    education:    '#0ea5e9',
    work:         '#f59e0b',
  };
  const TYPE_LABELS: Record<string, string> = {
    presentation: 'Presentation',
    education:    'Education',
    work:         'Work',
  };

  const filters: Record<string, boolean> = { presentation: true, education: true, work: true };

  // Build GeoJSON — one feature per unique coordinate, carrying all pins at that spot
  function buildGeoJSON() {
    const groups = new Map<string, any[]>();
    for (const pin of pinsData) {
      if (!filters[pin.type]) continue;
      const key = pin.coordinates.join(',');
      if (!groups.has(key)) groups.set(key, []);
      groups.get(key)!.push(pin);
    }

    return {
      type: 'FeatureCollection' as const,
      features: [...groups.values()].map((group) => ({
        type: 'Feature' as const,
        geometry: { type: 'Point' as const, coordinates: group[0].coordinates },
        properties: {
          count: group.length,
          type: group[0].type,
          color: group.length === 1
            ? TYPE_COLORS[group[0].type]
            : (new Set(group.map((p: any) => p.type)).size === 1 ? TYPE_COLORS[group[0].type] : '#8b5cf6'),
          pinsJson: JSON.stringify(group),
        },
      })),
    };
  }

  function createPopupHtml(pins: any[]) {
    const fmt = (d: string) => new Date(d).toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
    if (pins.length === 1) {
      const p = pins[0];
      const detail = p.venue || p.institution || p.company || '';
      return `<div style="max-width:240px">
        <div style="display:flex;align-items:center;gap:6px;margin-bottom:4px">
          <span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:${TYPE_COLORS[p.type]}"></span>
          <span style="font-size:11px;opacity:0.6">${TYPE_LABELS[p.type]}</span>
        </div>
        <div style="font-weight:600;font-size:13px;line-height:1.3">${p.title}</div>
        ${detail ? `<div style="font-size:12px;opacity:0.7;margin-top:2px">${detail}</div>` : ''}
        <div style="font-size:11px;opacity:0.5;margin-top:4px">${p.location} · ${fmt(p.date)}</div>
      </div>`;
    }
    const items = pins.map((p: any, i: number) => {
      const detail = p.venue || p.institution || p.company || '';
      return `<div style="padding:6px 0;${i > 0 ? 'border-top:1px solid rgba(0,0,0,0.08);' : ''}">
        <div style="display:flex;align-items:center;gap:6px;margin-bottom:2px">
          <span style="display:inline-block;width:6px;height:6px;border-radius:50%;background:${TYPE_COLORS[p.type]}"></span>
          <span style="font-size:10px;opacity:0.6">${TYPE_LABELS[p.type]}</span>
        </div>
        <div style="font-weight:600;font-size:12px;line-height:1.3">${p.title}</div>
        ${detail ? `<div style="font-size:11px;opacity:0.7">${detail}</div>` : ''}
        <div style="font-size:10px;opacity:0.5">${fmt(p.date)}</div>
      </div>`;
    }).join('');
    return `<div style="max-width:260px;max-height:300px;overflow-y:auto">
      <div style="font-size:11px;opacity:0.5;margin-bottom:4px">${pins[0].location} · ${pins.length} items</div>
      ${items}
    </div>`;
  }

  const map = new maplibregl.Map({
    container: container.id,
    style: 'https://basemaps.cartocdn.com/gl/voyager-gl-style/style.json',
    center: initialCenter,
    zoom: initialZoom,
    scrollZoom: true,
    dragRotate: false,
    pitchWithRotate: false,
  });

  map.addControl(new maplibregl.NavigationControl({ showCompass: false }), 'bottom-right');

  const popup = new maplibregl.Popup({ closeButton: true, maxWidth: '280px', offset: 8 });

  map.on('load', () => {
    // Source + layers
    map.addSource('pins', { type: 'geojson', data: buildGeoJSON() });

    // Outer ring (stroke)
    map.addLayer({
      id: 'pins-stroke',
      type: 'circle',
      source: 'pins',
      paint: {
        'circle-radius': ['case', ['>', ['get', 'count'], 1], 12, 8],
        'circle-color': ['get', 'color'],
        'circle-opacity': 0.25,
        'circle-stroke-width': 0,
      },
    });

    // Main circle
    map.addLayer({
      id: 'pins-fill',
      type: 'circle',
      source: 'pins',
      paint: {
        'circle-radius': ['case', ['>', ['get', 'count'], 1], 9, 6],
        'circle-color': ['get', 'color'],
        'circle-stroke-color': '#ffffff',
        'circle-stroke-width': 1.5,
        'circle-opacity': 0.92,
      },
    });

    // Count label for clusters
    map.addLayer({
      id: 'pins-label',
      type: 'symbol',
      source: 'pins',
      filter: ['>', ['get', 'count'], 1],
      layout: {
        'text-field': ['to-string', ['get', 'count']],
        'text-size': 10,
        'text-font': ['Open Sans Bold', 'Arial Unicode MS Bold'],
        'text-allow-overlap': true,
      },
      paint: { 'text-color': '#ffffff' },
    });

    // Click to show popup
    map.on('click', 'pins-fill', (e) => {
      if (!e.features?.length) return;
      const props = e.features[0].properties;
      const pins = JSON.parse(props.pinsJson);
      const coords = (e.features[0].geometry as any).coordinates;

      popup.setLngLat(coords).setHTML(createPopupHtml(pins)).addTo(map);

      document.querySelectorAll('.presentation-card-highlight').forEach((card) => {
        card.classList.remove('presentation-card-highlight');
      });
      for (const pin of pins) {
        const card = document.querySelector(`[data-content-id="${pin.contentId}"]`);
        if (card) {
          card.classList.add('presentation-card-highlight');
          if (pins.indexOf(pin) === 0) card.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
      }
    });

    // Hover cursor
    map.on('mouseenter', 'pins-fill', () => { map.getCanvas().style.cursor = 'pointer'; });
    map.on('mouseleave', 'pins-fill', () => { map.getCanvas().style.cursor = ''; });

    // Filters UI
    const filtersContainer = document.getElementById('map-filters');
    const filterConfig = [
      { key: 'presentation', label: 'Presentations', color: TYPE_COLORS.presentation },
      { key: 'education',    label: 'Education',     color: TYPE_COLORS.education },
      { key: 'work',         label: 'Work',           color: TYPE_COLORS.work },
    ];

    filterConfig.forEach((filter) => {
      const btn = document.createElement('button');
      const getClass = () => `filter-btn flex items-center gap-1 px-2 py-0.5 rounded-full text-xs cursor-pointer transition-all ${
        filters[filter.key] ? 'opacity-90 bg-white/20 shadow-sm' : 'opacity-30 bg-white/10'
      }`;
      btn.className = getClass();
      btn.innerHTML = `<span style="display:inline-block;width:6px;height:6px;border-radius:50%;background:${filter.color}"></span><span>${filter.label}</span>`;
      btn.addEventListener('click', () => {
        filters[filter.key] = !filters[filter.key];
        btn.className = getClass();
        (map.getSource('pins') as maplibregl.GeoJSONSource).setData(buildGeoJSON());
      });
      filtersContainer?.appendChild(btn);
    });
  });

  window.locationMap = {
    flyTo: (lng: number, lat: number, zoom = 8) => map.flyTo({ center: [lng, lat], zoom }),
    highlightPin: (pinId: string) => {
      const pin = pinsData.find((p: any) => p.id === pinId);
      if (pin) map.flyTo({ center: pin.coordinates, zoom: 8 });
    },
  };

  window.mapPins = pinsData;
</script>
