---
import ThemeSelector from './ThemeSelector.astro';
---

<header id="main-header" class="sticky top-0 z-40 border-b border-base-300/60 bg-base-100/95 backdrop-blur transition-transform duration-300">
  <nav class="navbar min-h-14 max-w-7xl mx-auto px-3 sm:px-6" aria-label="Primary navigation">
  <div class="navbar-start">
    <div class="dropdown">
      <button type="button" class="btn btn-ghost btn-sm btn-square lg:hidden" aria-label="Open navigation menu">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h8m-8 6h16" />
        </svg>
      </button>
      <ul tabindex="0" class="menu menu-sm dropdown-content mt-3 z-[1] p-2 shadow bg-base-100 rounded-box w-52">
        <li><a href="#about-me">About</a></li>
        <li><a href="#education">Education</a></li>
        <li><a href="#experience">Experience</a></li>
        <li><a href="#publications">Publications</a></li>
        <li><a href="#presentations">Presentations</a></li>
      </ul>
    </div>
    <a href="/" class="btn btn-ghost btn-sm text-base sm:text-lg">Daniele Zago</a>
  </div>
  <div class="navbar-center hidden lg:flex">
    <ul class="menu menu-horizontal px-1">
      <li><a href="#about-me">About</a></li>
      <li><a href="#education">Education</a></li>
      <li><a href="#experience">Experience</a></li>
      <li><a href="#publications">Publications</a></li>
      <li><a href="#presentations">Presentations</a></li>
    </ul>
  </div>
  <div class="navbar-end">
    <ThemeSelector />
  </div>
  </nav>
</header>

<script>
  let lastScrollY = window.scrollY;
  let ticking = false;
  const header = document.getElementById('main-header');

  function updateHeader() {
    const currentScrollY = window.scrollY;

    if (!header) return;

    // Always show header at top of page
    if (currentScrollY < 100) {
      header.style.transform = 'translateY(0)';
    }
    // Hide when scrolling down, show when scrolling up
    else if (currentScrollY > lastScrollY && currentScrollY > 100) {
      header.style.transform = 'translateY(-100%)';
    } else if (currentScrollY < lastScrollY) {
      header.style.transform = 'translateY(0)';
    }

    lastScrollY = currentScrollY;
    ticking = false;
  }

  function onScroll() {
    if (!ticking) {
      window.requestAnimationFrame(updateHeader);
      ticking = true;
    }
  }

  // Initialize scroll listener
  window.addEventListener('scroll', onScroll, { passive: true });

  // Reset header position when modal is closed
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (target.matches('.modal-backdrop, .modal-backdrop *')) {
      setTimeout(() => {
        lastScrollY = window.scrollY;
        updateHeader();
      }, 100);
    }
  });
</script>
