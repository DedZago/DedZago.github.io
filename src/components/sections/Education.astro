---
import { getCollection, render } from 'astro:content';

const education = await getCollection('education');

const degreeOrder: Record<string, number> = {
  'bsc-padova': 1,
  'msc-padova': 2,
  'phd-padova': 3,
};

const degreeLabels: Record<string, string> = {
  'bsc-padova': 'BSc',
  'msc-padova': 'MSc',
  'phd-padova': 'PhD',
};

const degrees = education
  .filter((entry) => entry.data.kind === 'degree')
  .sort((a, b) => (degreeOrder[a.id] ?? a.data.order) - (degreeOrder[b.id] ?? b.data.order));

const trainingByDegree = new Map(
  degrees.map((degree) => [
    degree.id,
    education
      .filter((entry) => entry.data.kind === 'training' && entry.data.parentDegree === degree.id)
      .sort((a, b) => a.data.order - b.data.order),
  ]),
);

const formatDateRange = (start: string, end?: string) => {
  return end ? `${start} — ${end}` : start;
};
---

<section id="education" class="py-12 lg:py-14 px-4 bg-base-200">
  <div class="max-w-7xl mx-auto">
    <h2 class="text-3xl font-bold text-center mb-3">Education</h2>
    <p class="text-center text-base-content/65 mb-9 max-w-xl mx-auto">
      Academic training in statistics, optimization, and scientific computing.
    </p>

    <ol class="degree-path" aria-label="Education progression">
      {degrees.map(async (degree) => {
        const { Content } = await render(degree);
        const relatedTraining = trainingByDegree.get(degree.id) ?? [];

        return (
          <li class="degree-stage">
            <div class="degree-marker" aria-hidden="true"></div>

            <article class="degree-card">
              <header class="degree-header">
                <span class="degree-label">{degreeLabels[degree.id]}</span>
                <span class="date-range">
                  {formatDateRange(degree.data.startDate, degree.data.endDate)}
                </span>
              </header>

              <h3>{degree.data.degree}</h3>
              {degree.data.field && <p class="degree-field">{degree.data.field}</p>}
              <p class="institution">
                {degree.data.institution}
                {degree.data.location && <span>{degree.data.location}</span>}
              </p>

              <div class="degree-details prose prose-sm max-w-none">
                <Content />
              </div>
            </article>

            {relatedTraining.length > 0 && (
              <div class="training-group" aria-label={`Training completed during ${degreeLabels[degree.id]}`}>
                <p class="training-context">During {degreeLabels[degree.id]}</p>
                {relatedTraining.map(async (training) => (
                  <article class="training-card">
                    <header>
                      <span class="training-label">Summer school</span>
                      <span class="training-date">{training.data.startDate}</span>
                    </header>
                    <h4>{training.data.degree}</h4>
                    <p class="training-institution">{training.data.institution}</p>
                    {training.data.field && <p class="training-topic">{training.data.field}</p>}
                  </article>
                ))}
              </div>
            )}
          </li>
        );
      })}
    </ol>
  </div>
</section>

<style>
  .degree-path {
    position: relative;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    grid-template-rows: auto auto auto;
    gap: 1.25rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .degree-path::before {
    content: '';
    position: absolute;
    top: 0.4rem;
    left: 16.666%;
    right: 16.666%;
    height: 2px;
    background: color-mix(in oklab, var(--color-primary) 25%, var(--color-base-300));
  }

  .degree-stage {
    position: relative;
    display: grid;
    grid-row: 1 / span 3;
    grid-template-rows: subgrid;
    row-gap: 1rem;
    min-width: 0;
  }

  .degree-marker {
    position: relative;
    z-index: 1;
    width: 0.85rem;
    height: 0.85rem;
    margin: 0 auto;
    border: 3px solid var(--color-base-200);
    border-radius: 50%;
    background: var(--color-primary);
    box-shadow: 0 0 0 1px color-mix(in oklab, var(--color-primary) 38%, transparent);
  }

  .degree-card {
    padding: 1.25rem;
    border: 1px solid color-mix(in oklab, var(--color-base-content) 10%, transparent);
    border-radius: 0.85rem;
    background: var(--color-base-100);
    box-shadow: 0 0.35rem 1.1rem color-mix(in oklab, var(--color-base-content) 7%, transparent);
    transition: transform 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
  }

  .degree-card:hover {
    border-color: color-mix(in oklab, var(--color-primary) 35%, transparent);
    box-shadow: 0 0.65rem 1.5rem color-mix(in oklab, var(--color-base-content) 10%, transparent);
    transform: translateY(-2px);
  }

  .degree-header,
  .training-card header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .degree-label,
  .training-label {
    color: var(--color-primary);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.07em;
    text-transform: uppercase;
  }

  .date-range,
  .training-date {
    color: color-mix(in oklab, var(--color-base-content) 55%, transparent);
    font-size: 0.72rem;
    font-weight: 650;
    white-space: nowrap;
  }

  .degree-card h3 {
    margin-top: 1rem;
    font-size: 1.15rem;
    font-weight: 750;
    line-height: 1.3;
  }

  .degree-field {
    margin-top: 0.35rem;
    color: color-mix(in oklab, var(--color-base-content) 72%, transparent);
    font-size: 0.9rem;
    line-height: 1.4;
  }

  .institution {
    display: flex;
    margin-top: 1rem;
    flex-direction: column;
    font-size: 0.84rem;
    font-weight: 700;
  }

  .institution span {
    color: color-mix(in oklab, var(--color-base-content) 52%, transparent);
    font-size: 0.76rem;
    font-weight: 450;
  }

  .degree-details {
    margin-top: 1rem;
    padding-top: 0.9rem;
    border-top: 1px solid color-mix(in oklab, var(--color-base-content) 9%, transparent);
    color: color-mix(in oklab, var(--color-base-content) 78%, transparent);
  }

  .degree-details :global(ul) {
    margin-block: 0;
    padding-inline-start: 1.1rem;
  }

  .degree-details :global(li) {
    margin-block: 0.3rem;
  }

  .training-group {
    position: relative;
    display: flex;
    margin: 0.25rem 0 0 1rem;
    padding-left: 1rem;
    flex-direction: column;
    border-left: 2px solid color-mix(in oklab, var(--color-primary) 24%, transparent);
  }

  .training-context {
    margin-bottom: 0.5rem;
    color: color-mix(in oklab, var(--color-base-content) 48%, transparent);
    font-size: 0.68rem;
    font-weight: 750;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .training-card {
    flex: 1;
    padding: 0.95rem 1rem;
    border: 1px solid color-mix(in oklab, var(--color-primary) 18%, transparent);
    border-radius: 0.7rem;
    background: color-mix(in oklab, var(--color-base-100) 92%, var(--color-primary));
    box-shadow: 0 0.2rem 0.8rem color-mix(in oklab, var(--color-base-content) 5%, transparent);
    transition: transform 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
  }

  .training-card:hover {
    border-color: color-mix(in oklab, var(--color-primary) 36%, transparent);
    box-shadow: 0 0.45rem 1rem color-mix(in oklab, var(--color-base-content) 8%, transparent);
    transform: translateY(-2px);
  }

  .training-card h4 {
    margin-top: 0.65rem;
    font-size: 0.9rem;
    font-weight: 750;
    line-height: 1.35;
  }

  .training-institution {
    margin-top: 0.4rem;
    color: var(--color-primary);
    font-size: 0.78rem;
    font-weight: 650;
  }

  .training-topic {
    margin-top: 0.35rem;
    color: color-mix(in oklab, var(--color-base-content) 67%, transparent);
    font-size: 0.76rem;
    line-height: 1.45;
  }

  @media (max-width: 900px) {
    .degree-path {
      display: flex;
      grid-template-columns: 1fr;
      grid-template-rows: none;
      gap: 1rem;
      padding-left: 1.5rem;
      flex-direction: column-reverse;
    }

    .degree-path::before {
      top: 0.75rem;
      bottom: 0.75rem;
      left: 0.4rem;
      right: auto;
      width: 2px;
      height: auto;
    }

    .degree-marker {
      position: absolute;
      top: 1.1rem;
      left: -1.5rem;
      margin: 0;
    }

    .degree-stage {
      display: flex;
      grid-row: auto;
      flex-direction: column;
    }

    .degree-card {
      min-height: 0;
    }

    .training-group {
      margin-top: 0.8rem;
    }

    .training-card {
      flex: none;
    }
  }
</style>
