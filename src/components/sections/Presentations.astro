---
import { getCollection } from 'astro:content';
import MapComponent from '@/components/map/MapComponent.astro';
import { ALL_PINS } from '@/lib/locationData';

const presentations = await getCollection('presentations');
const sortedPresentations = presentations.sort((a, b) => {
  // Sort by date (newest first)
  return b.data.date.getTime() - a.data.date.getTime();
});

const typeLabels = {
  'invited-talk': { text: 'Invited Talk', class: 'badge-primary' },
  'invited-seminar': { text: 'Invited Seminar', class: 'badge-secondary' },
  'poster': { text: 'Poster', class: 'badge-accent' },
  'workshop': { text: 'Workshop', class: 'badge-info' },
};

// Format date as "Mon YYYY"
const formatDate = (date: Date) => {
  return date.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
};
---

<section id="presentations" class="py-12 lg:py-14 px-4">
  <div class="max-w-7xl mx-auto">
    <h2 class="text-3xl font-bold text-center mb-4">Conference Presentations</h2>
    <p class="text-center text-base-content/70 mb-8 max-w-2xl mx-auto">
      Selected presentations on stochastic optimization, statistical process monitoring, and decision sciences.
    </p>

    <div class="grid lg:grid-cols-[minmax(0,1.15fr)_minmax(0,1fr)] gap-6 items-start">
      <!-- Presentations List -->
      <div class="space-y-3 order-2 lg:order-1">
        {sortedPresentations.map((pres) => (
          <div
            data-content-id={pres.id}
            class="card bg-base-100 shadow-md hover:shadow-lg transition-all cursor-pointer"
          >
            <div class="card-body p-4 gap-2">
              <div class="presentation-layout">
                <!-- Date, type, and map action -->
                <div class="presentation-meta">
                  <div class="text-sm font-mono text-base-content/60 whitespace-nowrap">
                    {formatDate(pres.data.date)}
                  </div>

                  <span class={`badge badge-sm ${typeLabels[pres.data.type].class} whitespace-nowrap`}>
                    {typeLabels[pres.data.type].text}
                  </span>

                  <button class="btn btn-ghost btn-sm btn-square" aria-label="View on map" data-show-on-map={pres.id}>
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                    </svg>
                  </button>
                </div>

                <!-- Presentation details -->
                <div class="presentation-content">
                  <h3 class="font-semibold text-lg leading-tight">
                    {pres.data.title}
                  </h3>
                  <p class="text-sm text-base-content/70 mt-1">
                    {pres.data.venue}
                    {pres.data.location && `, ${pres.data.location}`}
                  </p>

                  {pres.data.slidesUrl && (
                    <a href={pres.data.slidesUrl} target="_blank" rel="noopener noreferrer"
                       class="btn btn-ghost btn-xs mt-2 px-0">
                      Slides <span aria-hidden="true">↗</span>
                    </a>
                  )}
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Interactive Map -->
      <div class="lg:sticky lg:top-8 order-1 lg:order-2">
        <div class="card bg-base-100 shadow-lg overflow-hidden">
          <div class="card-body p-0">
            <MapComponent pins={ALL_PINS} />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .presentation-layout {
    display: grid;
    grid-template-columns: 8.5rem minmax(0, 1fr);
    gap: 1rem;
    align-items: start;
  }

  .presentation-meta {
    display: flex;
    min-width: 0;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.55rem;
  }

  .presentation-content {
    min-width: 0;
  }

  @media (max-width: 480px) {
    .presentation-layout {
      grid-template-columns: 7.5rem minmax(0, 1fr);
      gap: 0.75rem;
    }

    .presentation-content h3 {
      font-size: 1rem;
    }
  }
</style>

<script>
  document.querySelectorAll('[data-show-on-map]').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const id = (e.currentTarget as HTMLElement).dataset.showOnMap;
      if (id && window.mapPins && window.locationMap) {
        const pin = window.mapPins.find((p) => p.contentId === id);
        if (pin) {
          window.locationMap.flyTo(pin.coordinates[0], pin.coordinates[1], 8);
          window.locationMap.highlightPin(pin.id);
        }
      }
    });
  });
</script>
