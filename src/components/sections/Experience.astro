---
import { getCollection, render } from 'astro:content';
import Modal from '@/components/common/Modal.astro';

const experience = await getCollection('experience');
const sortedExperience = experience.sort((a, b) => a.data.order - b.data.order);

const formatDateRange = (start: string, end?: string) => {
  return end ? `${start} — ${end}` : start;
};

const getYear = (date?: string) => {
  const match = date?.match(/\b\d{4}\b/);
  return match ? Number(match[0]) : undefined;
};

// A dated entry without an end date is grouped under the narrowest bounded
// experience whose date range contains it.
const parentByChildId = new Map<string, string>();

for (const child of sortedExperience) {
  if (child.data.endDate) continue;

  const childYear = getYear(child.data.startDate);
  if (!childYear) continue;

  const parent = sortedExperience
    .filter((candidate) => {
      if (candidate.id === child.id || !candidate.data.endDate) return false;
      if (candidate.data.endDate.toLowerCase() === 'present') return false;

      const startYear = getYear(candidate.data.startDate);
      const endYear = getYear(candidate.data.endDate);
      return startYear !== undefined && endYear !== undefined
        && childYear >= startYear && childYear <= endYear;
    })
    .sort((a, b) => {
      const aDuration = getYear(a.data.endDate)! - getYear(a.data.startDate)!;
      const bDuration = getYear(b.data.endDate)! - getYear(b.data.startDate)!;
      return aDuration - bDuration;
    })[0];

  if (parent) parentByChildId.set(child.id, parent.id);
}

const experienceGroups = sortedExperience
  .filter((entry) => !parentByChildId.has(entry.id))
  .map((primary) => ({
    primary,
    secondary: sortedExperience.filter((entry) => parentByChildId.get(entry.id) === primary.id),
  }));
---

<section id="experience" class="py-12 lg:py-14 px-4">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-3xl font-bold text-center mb-4">Experience</h2>
    <p class="text-center text-base-content/70 mb-8 max-w-2xl mx-auto">
      Experienced in mathematical optimization, machine learning, and statistical computing, with applications in operations research and industrial statistics.
    </p>

    <div class="experience-timeline">
      {experienceGroups.map(({ primary, secondary }) => {
        const primaryModalId = `modal-experience-${primary.id}`;

        return (
          <article class="experience-group">
            <span class="timeline-dot" aria-hidden="true"></span>

            <div class:list={['experience-layout', { 'has-secondary': secondary.length > 0 }]}>
              <button
                type="button"
                class="experience-card primary-card"
                onclick={`document.getElementById('${primaryModalId}').showModal()`}
                aria-label={`Read more about ${primary.data.title} at ${primary.data.company}`}
              >
                <span class="badge badge-primary badge-sm">
                  {formatDateRange(primary.data.startDate, primary.data.endDate)}
                </span>
                <span class="experience-title">{primary.data.title}</span>
                <span class="experience-company">{primary.data.company}</span>
                <span class="experience-location">{primary.data.location}</span>
                {primary.data.summary && (
                  <span class="experience-summary">{primary.data.summary}</span>
                )}
                {primary.body && <span class="read-more">Read more <span aria-hidden="true">→</span></span>}
              </button>

              {secondary.length > 0 && (
                <div class="secondary-column">
                  {secondary.map((entry) => {
                    const modalId = `modal-experience-${entry.id}`;
                    return (
                      <button
                        type="button"
                        class="experience-card secondary-card"
                        onclick={`document.getElementById('${modalId}').showModal()`}
                        aria-label={`Read more about ${entry.data.title} at ${entry.data.company}`}
                      >
                        <span class="secondary-meta">
                          <span class="badge badge-outline badge-sm">
                            {formatDateRange(entry.data.startDate, entry.data.endDate)}
                          </span>
                          <span class="concurrent-label">Concurrent</span>
                        </span>
                        <span class="experience-title secondary-title">{entry.data.title}</span>
                        <span class="experience-company">{entry.data.company}</span>
                        {entry.data.summary && (
                          <span class="experience-summary secondary-summary">{entry.data.summary}</span>
                        )}
                      </button>
                    );
                  })}
                </div>
              )}
            </div>
          </article>
        );
      })}
    </div>

    {sortedExperience.map(async (entry) => {
      const { Content } = await render(entry);
      return (
        <Modal
          id={`modal-experience-${entry.id}`}
          title={entry.data.title}
          company={entry.data.company}
          location={entry.data.location}
          dateRange={formatDateRange(entry.data.startDate, entry.data.endDate)}
        >
          <Content />
        </Modal>
      );
    })}
  </div>
</section>

<style>
  .experience-timeline {
    position: relative;
    display: grid;
    gap: 1.25rem;
    padding-left: 2.5rem;
  }

  .experience-timeline::before {
    content: '';
    position: absolute;
    top: 0.5rem;
    bottom: 0.5rem;
    left: 0.45rem;
    width: 2px;
    background: color-mix(in oklab, var(--color-base-content) 16%, transparent);
  }

  .experience-group {
    position: relative;
  }

  .timeline-dot {
    position: absolute;
    top: 1.4rem;
    left: -2.5rem;
    width: 0.95rem;
    height: 0.95rem;
    border: 4px solid var(--color-base-100);
    border-radius: 50%;
    background: var(--color-primary);
    box-shadow: 0 0 0 1px color-mix(in oklab, var(--color-primary) 35%, transparent);
    z-index: 1;
  }

  .experience-layout {
    display: grid;
    gap: 0.875rem;
  }

  .experience-card {
    width: 100%;
    min-width: 0;
    border: 1px solid color-mix(in oklab, var(--color-base-content) 10%, transparent);
    border-radius: 0.5rem;
    background: var(--color-base-100);
    color: var(--color-base-content);
    text-align: left;
    box-shadow: 0 0.35rem 1.1rem color-mix(in oklab, var(--color-base-content) 7%, transparent);
    transition: border-color 160ms ease, box-shadow 160ms ease, transform 160ms ease;
    cursor: pointer;
  }

  .experience-card:hover,
  .experience-card:focus-visible {
    border-color: color-mix(in oklab, var(--color-primary) 42%, transparent);
    box-shadow: 0 0.65rem 1.6rem color-mix(in oklab, var(--color-base-content) 11%, transparent);
    transform: translateY(-2px);
  }

  .experience-card:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 3px;
  }

  .primary-card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    padding: 1.1rem;
  }

  .experience-title {
    display: block;
    margin-top: 0.65rem;
    font-size: 1.125rem;
    font-weight: 700;
    line-height: 1.3;
  }

  .experience-company {
    display: block;
    margin-top: 0.2rem;
    color: var(--color-primary);
    font-size: 0.9rem;
    font-weight: 600;
  }

  .experience-location {
    display: block;
    margin-top: 0.15rem;
    color: color-mix(in oklab, var(--color-base-content) 58%, transparent);
    font-size: 0.82rem;
  }

  .experience-summary {
    display: block;
    display: -webkit-box;
    margin-top: 0.65rem;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    color: color-mix(in oklab, var(--color-base-content) 80%, transparent);
    font-size: 0.9rem;
    line-height: 1.55;
  }

  .read-more {
    display: block;
    margin-top: auto;
    padding-top: 0.65rem;
    color: var(--color-primary);
    font-size: 0.78rem;
    font-weight: 700;
  }

  .secondary-column {
    display: grid;
    align-content: start;
    gap: 0.65rem;
  }

  .secondary-card {
    display: block;
    padding: 0.85rem;
    border-left: 3px solid color-mix(in oklab, var(--color-primary) 65%, transparent);
    box-shadow: 0 0.2rem 0.8rem color-mix(in oklab, var(--color-base-content) 6%, transparent);
  }

  .secondary-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .concurrent-label {
    color: color-mix(in oklab, var(--color-base-content) 48%, transparent);
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .secondary-title {
    margin-top: 0.6rem;
    font-size: 0.98rem;
  }

  .secondary-summary {
    display: -webkit-box;
    margin-top: 0.65rem;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
    font-size: 0.8rem;
    line-height: 1.45;
  }

  @media (min-width: 768px) {
    .experience-timeline {
      padding-left: 3rem;
    }

    .timeline-dot {
      left: -3rem;
    }

    .experience-layout.has-secondary {
      grid-template-columns: minmax(0, 1.65fr) minmax(15rem, 1fr);
      align-items: stretch;
    }
  }

  @media (max-width: 767px) {
    .secondary-column {
      padding-left: 0.75rem;
      border-left: 1px solid color-mix(in oklab, var(--color-primary) 25%, transparent);
    }
  }
</style>
