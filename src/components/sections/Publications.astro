---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import { render } from 'astro:content';

const software = await getCollection('software');
const sortedSoftware = software.sort((a, b) => a.data.order - b.data.order);

const publications = await getCollection('publications');
const publishedPapers = publications
  .filter(p => p.data.status === 'published')
  .sort((a, b) => {
    if (a.data.order !== b.data.order) return a.data.order - b.data.order;
    return b.data.date.getTime() - a.data.date.getTime();
  });

const unpublishedPapers = publications
  .filter(p => p.data.status !== 'published')
  .sort((a, b) => {
    if (a.data.order !== b.data.order) return a.data.order - b.data.order;
    return b.data.date.getTime() - a.data.date.getTime();
  });

const statusLabels = {
  'published': { text: 'Published', class: 'badge-success' },
  'submitted': { text: 'Submitted', class: 'badge-warning' },
  'in-preparation': { text: 'In Prep', class: 'badge-info' },
};
---

<section id="publications" class="py-16 px-4">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-3xl font-bold text-center mb-4">Publications & Software</h2>
    <p class="text-center text-base-content/70 mb-12 max-w-2xl mx-auto">
      Research in statistical computing, mathematical optimization, and decision sciences.
    </p>

    {/* Software Section */}
    {sortedSoftware.length > 0 && (
      <div class="mb-16">
        <h3 class="text-2xl font-bold mb-6">Software</h3>
        <div class="grid gap-8 md:grid-cols-2">
          {sortedSoftware.map(async (pkg, index) => {
            const { Content } = await render(pkg);
            const modalId = `modal-software-${index}`;
            return (
              <>
                <div
                  class="card bg-base-100 shadow-xl lg:card-side hover:shadow-2xl transition-all duration-300 cursor-pointer hover:-translate-y-1"
                  onclick={`document.getElementById('${modalId}').showModal()`}
                >
                  {pkg.data.image && (
                    <figure class="lg:w-1/3">
                      <Image
                        src={pkg.data.image}
                        alt={pkg.data.title}
                        width={600}
                        height={400}
                        class="h-full w-full object-cover"
                        format="webp"
                        quality={90}
                      />
                    </figure>
                  )}
                  <div class="card-body lg:w-2/3">
                    <h4 class="card-title">
                      {pkg.data.title}
                      {pkg.data.language && (
                        <span class="badge badge-outline badge-sm">{pkg.data.language}</span>
                      )}
                    </h4>
                    {pkg.data.journal && (
                      <p class="text-sm text-primary italic">{pkg.data.journal}</p>
                    )}
                    <div class="text-sm line-clamp-3">
                      <Content />
                    </div>
                    <p class="text-xs text-base-content/60 italic mt-2">Click to read more</p>
                  </div>
                </div>

                {/* Modal for software */}
                <dialog id={modalId} class="modal modal-bottom sm:modal-middle">
                  <div class="modal-box max-w-3xl">
                    <form method="dialog">
                      <button class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2">✕</button>
                    </form>
                    {pkg.data.image && (
                      <figure class="mb-4">
                        <Image
                          src={pkg.data.image}
                          alt={pkg.data.title}
                          width={800}
                          height={400}
                          class="rounded-xl w-full object-cover"
                          format="webp"
                        />
                      </figure>
                    )}
                    <h3 class="font-bold text-2xl mb-2">
                      {pkg.data.title}
                      {pkg.data.language && (
                        <span class="badge badge-outline badge-sm ml-2">{pkg.data.language}</span>
                      )}
                    </h3>
                    {pkg.data.journal && (
                      <p class="text-sm text-primary italic mb-4">{pkg.data.journal}</p>
                    )}
                    <div class="prose prose-sm max-w-none">
                      <Content />
                    </div>
                    <div class="flex gap-3 mt-6 justify-end">
                      {pkg.data.journalUrl && (
                        <a href={pkg.data.journalUrl} target="_blank" rel="noopener noreferrer"
                           class="btn btn-outline btn-sm" onclick="event.stopPropagation()">
                          Paper
                        </a>
                      )}
                      <a href={pkg.data.githubUrl} target="_blank" rel="noopener noreferrer"
                         class="btn btn-primary btn-sm gap-2" onclick="event.stopPropagation()">
                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                        </svg>
                        Source Code
                      </a>
                    </div>
                  </div>
                  <form method="dialog" class="modal-backdrop">
                    <button>close</button>
                  </form>
                </dialog>
              </>
            );
          })}
        </div>
      </div>
    )}

    {/* Published Papers Section */}
    {publishedPapers.length > 0 && (
      <div class="mb-16">
        <h3 class="text-2xl font-bold mb-6">Published Articles</h3>
        <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
          {publishedPapers.map(async (pub, index) => {
            const { Content } = await render(pub);
            const modalId = `modal-pub-${index}`;
            return (
              <>
                <div
                  class="card bg-base-100 shadow-xl hover:shadow-2xl transition-all duration-300 cursor-pointer hover:-translate-y-1"
                  onclick={`document.getElementById('${modalId}').showModal()`}
                >
                  {pub.data.image && (
                    <figure class="px-4 pt-4">
                      <Image
                        src={pub.data.image}
                        alt={pub.data.title}
                        width={800}
                        height={500}
                        class="rounded-xl object-cover h-48 w-full"
                        format="webp"
                        quality={90}
                      />
                    </figure>
                  )}
                  <div class="card-body">
                    <h4 class="card-title text-lg">
                      {pub.data.title}
                    </h4>
                    {pub.data.journal && (
                      <p class="text-sm text-primary italic">{pub.data.journal}</p>
                    )}
                    <div class="text-sm text-base-content/70 line-clamp-3">
                      <Content />
                    </div>
                    <p class="text-xs text-base-content/60 italic mt-2">Click to read more</p>
                  </div>
                </div>

                {/* Modal for publication */}
                <dialog id={modalId} class="modal modal-bottom sm:modal-middle">
                  <div class="modal-box max-w-3xl">
                    <form method="dialog">
                      <button class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2">✕</button>
                    </form>
                    {pub.data.image && (
                      <figure class="mb-4">
                        <Image
                          src={pub.data.image}
                          alt={pub.data.title}
                          width={800}
                          height={400}
                          class="rounded-xl w-full object-cover"
                          format="webp"
                        />
                      </figure>
                    )}
                    <h3 class="font-bold text-2xl mb-2">{pub.data.title}</h3>
                    {pub.data.journal && (
                      <p class="text-sm text-primary italic mb-4">{pub.data.journal}</p>
                    )}
                    <div class="prose prose-sm max-w-none">
                      <Content />
                    </div>
                    {pub.data.url && (
                      <div class="mt-6 flex justify-end">
                        <a href={pub.data.url} target="_blank" rel="noopener noreferrer"
                           class="btn btn-primary btn-sm" onclick="event.stopPropagation()">
                          View Article
                        </a>
                      </div>
                    )}
                  </div>
                  <form method="dialog" class="modal-backdrop">
                    <button>close</button>
                  </form>
                </dialog>
              </>
            );
          })}
        </div>
      </div>
    )}

    {/* Unpublished Papers Section - Enhanced Cards */}
    {unpublishedPapers.length > 0 && (
      <div>
        <h3 class="text-2xl font-bold mb-6">Under Review & In Preparation</h3>
        <div class="grid gap-6 md:grid-cols-2">
          {unpublishedPapers.map(async (pub, index) => {
            const { Content } = await render(pub);
            const modalId = `modal-unpub-${index}`;
            return (
              <>
                <div
                  class="card bg-base-100 shadow-xl hover:shadow-2xl transition-all duration-300 cursor-pointer hover:-translate-y-1"
                  onclick={`document.getElementById('${modalId}').showModal()`}
                >
                  {pub.data.image && (
                    <figure class="px-4 pt-4">
                      <Image
                        src={pub.data.image}
                        alt={pub.data.title}
                        width={800}
                        height={500}
                        class="rounded-xl object-cover h-40 w-full"
                        format="webp"
                        quality={90}
                      />
                    </figure>
                  )}
                  <div class="card-body">
                    <h4 class="card-title text-base">
                      {pub.data.title}
                      <span class={`badge ${statusLabels[pub.data.status].class} badge-xs`}>
                        {statusLabels[pub.data.status].text}
                      </span>
                    </h4>
                    {pub.data.journal && (
                      <p class="text-sm text-primary italic">{pub.data.journal}</p>
                    )}
                    <div class="text-sm text-base-content/70 line-clamp-3">
                      <Content />
                    </div>
                    <p class="text-xs text-base-content/60 italic mt-2">Click to read more</p>
                  </div>
                </div>

                {/* Modal for unpublished publication */}
                <dialog id={modalId} class="modal modal-bottom sm:modal-middle">
                  <div class="modal-box max-w-3xl">
                    <form method="dialog">
                      <button class="btn btn-sm btn-circle btn-ghost absolute right-2 top-2">✕</button>
                    </form>
                    {pub.data.image && (
                      <figure class="mb-4">
                        <Image
                          src={pub.data.image}
                          alt={pub.data.title}
                          width={800}
                          height={400}
                          class="rounded-xl w-full object-cover"
                          format="webp"
                        />
                      </figure>
                    )}
                    <h3 class="font-bold text-2xl mb-2">
                      {pub.data.title}
                      <span class={`badge ${statusLabels[pub.data.status].class} badge-sm ml-2`}>
                        {statusLabels[pub.data.status].text}
                      </span>
                    </h3>
                    {pub.data.journal && (
                      <p class="text-sm text-primary italic mb-4">{pub.data.journal}</p>
                    )}
                    <div class="prose prose-sm max-w-none">
                      <Content />
                    </div>
                    {pub.data.url && (
                      <div class="mt-6 flex justify-end">
                        <a href={pub.data.url} target="_blank" rel="noopener noreferrer"
                           class="btn btn-primary btn-sm" onclick="event.stopPropagation()">
                          Details →
                        </a>
                      </div>
                    )}
                  </div>
                  <form method="dialog" class="modal-backdrop">
                    <button>close</button>
                  </form>
                </dialog>
              </>
            );
          })}
        </div>
      </div>
    )}
  </div>
</section>
